                9606,
                "P24394",
                "ENSG00000077238",
                "IL4R",
                "unspecified role",
                9606
            ],
            [
                2,
                "signor",
                "P35225",
                "ENSG00000169194",
                "IL13",
                "regulator",
                9606,
                "P24394",
                "ENSG00000077238",
                "IL4R",
                "regulator target",
                9606
            ],
            [
                3,
                "reactome",
                "P35225",
                "ENSG00000169194",
                "IL13",
                "unspecified role",
                9606,
                "P24394",
                "ENSG00000077238",
                "IL4R",
                "unspecified role",
                9606
            ]
        ]
    },
