        "expected_result": "961ff37ddc5a0cf34de084df607d70e0"
    },
    "test_opentargets_pharmacogenetics_filter_or": {
        "type": "assert_equal_json_hash_nested",
        "args": {
            "ensembl_id": "ENSG00000130164",
            "resource": "pharmacogenetics",
            "filters": {
                "drug_id": [
                    "CHEMBL1643",
                    "CHEMBL24"
                ]
            },
            "filter_mode": "or"
        },
