    "test_opentargets_interactions_simple_filter": {
        "type": "assert_equal",
        "args": {
            "ensembl_id": "ENSG00000169194",
            "resource": "interactions",
            "filters": {
                "protein_a_id": "P35225",
                "gene_b_id": "ENSG00000077238"
            }
        },
        "expected_result": [
            [
                1,
                "intact",
                "P35225",
                "ENSG00000169194",
