  "test_opentargets_depmap": {
    "function_call_to_reproduce": "output = opentargets(ensembl_id='ENSG00000169194', resource='depmap', limit=2, json=True, verbose=False); print(json.dumps(output, indent=2))",
    "type": "assert_equal_json_with_keys",
    "args": {
      "ensembl_id": "ENSG00000169194",
      "resource": "depmap",
      "limit": 2
    },
    "expected_result": [
      {
        "tissueId": "UBERON_0002367",
        "tissueName": "prostate gland",
        "cellLineName": "DU 145",
        "expression": 0.0343439169,
        "diseaseFromSource": "Prostate Adenocarcinoma",
        "depmapId": "ACH-000979",
        "geneEffect": -0.1433678865
      },
      {
        "tissueId": "UBERON_0002367",
        "tissueName": "prostate gland",
        "cellLineName": "WPE1-NA22",
        "expression": 0.0291899424,
        "diseaseFromSource": "Non-Cancerous",
        "depmapId": "ACH-001422",
        "geneEffect": 0.069347702
      }
    ]
  },
  "test_opentargets_diseases": {
