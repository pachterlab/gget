    "test_opentargets_depmap_filter": {
        "type": "assert_equal",
        "args": {
            "ensembl_id": "ENSG00000169194",
            "resource": "depmap",
            "filters": {
                "tissue_id": "UBERON_0002367"
            },
            "limit": 2
        },
        "expected_result": [
            [
                "ACH-000979",
                0.034343916922807693,
                -0.14336788654327393,
                "UBERON_0002367",
                "prostate gland",
                "DU 145",
                "Prostate Adenocarcinoma"
            ],
            [
                "ACH-001422",
                0.0291899424046278,
                0.06934770196676254,
                "UBERON_0002367",
                "prostate gland",
                "WPE1-NA22",
                "Non-Cancerous"
            ]
        ]
    },
